generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMINISTRADOR
  GERENTE
  FUNCIONARIO
}

enum BannerType {
  HERO
  HORIZONTAL
  PROMOCIONAL
  INSTITUCIONAL
}

model User {
  id            String         @id @default(uuid())
  nome          String
  email         String         @unique
  senha         String
  cargo         UserRole       @default(FUNCIONARIO)
  ativo         Boolean        @default(true)
  ultimoLogin   DateTime?      @map("ultimo_login")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model Banner {
  id                   String     @id @default(uuid())
  nome                 String?
  titulo               String
  subtitulo            String?
  descricao            String?
  imagemDesktop        String     @map("imagem_desktop")
  imagemMobile         String?    @map("imagem_mobile")
  tipo                 BannerType
  link                 String?
  textoBotaoPrimario   String?    @map("texto_botao_primario")
  textoBotaoSecundario String?    @map("texto_botao_secundario")
  linkPrimario         String?    @map("link_primario")
  linkSecundario       String?    @map("link_secundario")
  ordem                Int        @default(0)
  ativo                Boolean    @default(true)
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  @@map("banners")
}

model Category {
  id              String     @id @default(uuid())
  nome            String
  slug            String     @unique
  descricao       String
  imagem          String
  banner          String
  categoriaPaiId  String?    @map("categoria_pai_id")
  categoriaPai    Category?  @relation("CategoryHierarchy", fields: [categoriaPaiId], references: [id], onDelete: SetNull)
  subcategorias   Category[] @relation("CategoryHierarchy")
  ordem           Int        @default(0)
  ativo           Boolean    @default(true)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@map("categories")
}
