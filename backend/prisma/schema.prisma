  id                     String               @id @default(uuid())
  accountPayableId       String               @map("account_payable_id")
  accountPayable         AccountPayable       @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)
  financialTransactionId String               @unique @map("financial_transaction_id")
  financialTransaction   FinancialTransaction @relation(fields: [financialTransactionId], references: [id], onDelete: Restrict)
  valor                  Decimal              @db.Decimal(12, 2)
  paymentMethodId        String               @map("payment_method_id")
  paymentMethod          FinancialPaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  financialAccountId     String?              @map("financial_account_id")
  financialAccount       FinancialAccount?    @relation("PaymentBankAccount", fields: [financialAccountId], references: [id], onDelete: SetNull)
  cashboxId              String?              @map("cashbox_id")
  cashbox                FinancialCashbox?    @relation(fields: [cashboxId], references: [id], onDelete: SetNull)
  pagoEm                 DateTime             @map("pago_em")
  usuarioId              String?              @map("usuario_id")
  usuario                User?                @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  estornado              Boolean              @default(false)
  estornoTransactionId   String?              @unique @map("estorno_transaction_id")
  estornoTransaction     FinancialTransaction? @relation("PaymentReversalTransaction", fields: [estornoTransactionId], references: [id], onDelete: SetNull)
  createdAt              DateTime             @default(now()) @map("created_at")

  @@index([accountPayableId])
  @@index([pagoEm])
  @@map("accounts_payable_payments")
}

model AccountPayableHistory {
  id               String         @id @default(uuid())
  accountPayableId String         @map("account_payable_id")
  accountPayable   AccountPayable @relation(fields: [accountPayableId], references: [id], onDelete: Cascade)
  operacao         String
  usuarioId        String?        @map("usuario_id")
  usuario          User?          @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  descricao        String
  valorAnterior    Decimal?       @map("valor_anterior") @db.Decimal(12, 2)
  valorNovo        Decimal?       @map("valor_novo") @db.Decimal(12, 2)
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([accountPayableId])
  @@index([createdAt])
  @@map("accounts_payable_history")
}

model Expense {
  id                   String                      @id @default(uuid())
  numero               Int                         @unique
  supplierId           String?                     @map("supplier_id")
  supplier             Supplier?                   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  categoryId           String                      @map("category_id")
  category             FinancialCategory           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  chartAccountId       String                      @map("chart_account_id")
  chartAccount         FinancialChartAccount       @relation(fields: [chartAccountId], references: [id], onDelete: Restrict)
  costCenterId         String                      @map("cost_center_id")
  costCenter           FinancialCostCenter         @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
  financialAccountId   String?                     @map("financial_account_id")
  financialAccount     FinancialAccount?           @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  paymentMethodId      String?                     @map("payment_method_id")
  paymentMethod        FinancialPaymentMethod?     @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  accountPayableId     String                      @unique @map("account_payable_id")
  accountPayable       AccountPayable              @relation(fields: [accountPayableId], references: [id], onDelete: Restrict)
  descricao            String
  documento            String?
  valor                Decimal                     @db.Decimal(12, 2)
  competencia          DateTime
  vencimento           DateTime
  status               ExpenseStatus               @default(PENDENTE)
  recorrente           Boolean                     @default(false)
  frequencia           ExpenseRecurrenceFrequency?
  variavel             Boolean                     @default(true)
  grupoParcelasId      String?                     @map("grupo_parcelas_id")
  parcelaNumero        Int?                        @map("parcela_numero")
  totalParcelas        Int?                        @map("total_parcelas")
  recorrenciaOrigemId  String?                     @map("recorrencia_origem_id")
  recorrenciaOrigem    Expense?                    @relation("ExpenseRecurrence", fields: [recorrenciaOrigemId], references: [id], onDelete: SetNull)
  ocorrenciasRecorrentes Expense[]                 @relation("ExpenseRecurrence")
  proximaRecorrencia   DateTime?                   @map("proxima_recorrencia")
  observacoes          String?
  usuarioId            String?                     @map("usuario_id")
  usuario              User?                       @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  deletedAt            DateTime?                   @map("deleted_at")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")
  parcela              ExpenseInstallment?
  anexos               ExpenseAttachment[]
  historico            ExpenseHistory[]

  @@index([supplierId])
  @@index([categoryId])
  @@index([costCenterId])
  @@index([vencimento])
  @@index([status])
  @@index([grupoParcelasId])
  @@index([recorrente])
  @@map("expenses")
}

model ExpenseInstallment {
  id         String        @id @default(uuid())
  grupoId    String        @map("grupo_id")
  expenseId  String        @unique @map("expense_id")
  expense    Expense       @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  numero     Int
  valor      Decimal       @db.Decimal(12, 2)
  vencimento DateTime
  status     ExpenseStatus @default(PENDENTE)
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([grupoId])
  @@index([vencimento])
  @@index([status])
  @@map("expense_installments")
}

model ExpenseAttachment {
  id         String   @id @default(uuid())
  expenseId  String   @map("expense_id")
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  nome       String
  arquivo    String
  tipo       String
  usuarioId  String?  @map("usuario_id")
  usuario    User?    @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([expenseId])
  @@map("expense_attachments")
}

model ExpenseHistory {
  id            String   @id @default(uuid())
  expenseId     String   @map("expense_id")
  expense       Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  operacao      String
  descricao     String
  usuarioId     String?  @map("usuario_id")
  usuario       User?    @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  valorAnterior Decimal? @map("valor_anterior") @db.Decimal(12, 2)
  valorNovo     Decimal? @map("valor_novo") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([expenseId])
  @@index([createdAt])
  @@map("expense_history")
}

model DeliverySettings {
  id                  String                   @id @default("default")
  enabled             Boolean                  @default(true)
  minimumOrderValue   Decimal                  @default(0) @map("minimum_order_value") @db.Decimal(10, 2)
  averageDeliveryTime Int                      @default(45) @map("average_delivery_time")
  message             String                   @default("Entrega realizada pela própria loja.")
  closedMessage       String                   @default("No momento estamos fora do horário de entrega.") @map("closed_message")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  businessHours       DeliveryBusinessHour[]
  history             DeliverySettingsHistory[]

  @@map("delivery_settings")
}

model DeliveryBusinessHour {
  id         String           @id @default(uuid())
  settingsId String           @map("settings_id")
  settings   DeliverySettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  weekday    Weekday
  isOpen     Boolean          @default(true) @map("is_open")
  startTime  String           @default("09:00") @map("start_time")
  endTime    String           @default("18:00") @map("end_time")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  @@unique([settingsId, weekday])
  @@map("delivery_business_hours")
}

model DeliverySettingsHistory {
  id         String           @id @default(uuid())
  settingsId String           @map("settings_id")
  settings   DeliverySettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  operacao   String
  descricao  String
  usuarioId  String?          @map("usuario_id")
  usuario    User?            @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([settingsId])
  @@index([createdAt])
  @@map("delivery_settings_history")
}

model DeliveryNeighborhood {
  id                    String                      @id @default(uuid())
  name                  String
  city                  String
  state                 String
  deliveryFee           Decimal                     @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  averageDeliveryTime   Int                         @default(45) @map("average_delivery_time")
  isActive              Boolean                     @default(true) @map("is_active")
  notes                 String?
  deletedAt             DateTime?                   @map("deleted_at")
  createdAt             DateTime                    @default(now()) @map("created_at")
  updatedAt             DateTime                    @updatedAt @map("updated_at")
  pedidos               Order[]
  history               DeliveryNeighborhoodHistory[]

  @@index([name])
  @@index([city])
  @@index([state])
  @@index([isActive])
  @@index([deletedAt])
  @@map("delivery_neighborhoods")
}

model DeliveryNeighborhoodHistory {
  id             String               @id @default(uuid())
  neighborhoodId String               @map("neighborhood_id")
  neighborhood   DeliveryNeighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  operacao       String
  descricao      String
  usuarioId      String?              @map("usuario_id")
  usuario        User?                @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  createdAt      DateTime             @default(now()) @map("created_at")

  @@index([neighborhoodId])
  @@index([createdAt])
  @@map("delivery_neighborhood_history")
}

model DeliveryPerson {
  id        String               @id @default(uuid())
  name      String
  phone     String
  cpf       String?
  document  String?
  status    DeliveryPersonStatus @default(DISPONIVEL)
  notes     String?
  deletedAt DateTime?            @map("deleted_at")
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")
  pedidos   Order[]
  entregas  Delivery[]
  history   DeliveryPersonHistory[]

  @@index([name])
  @@index([phone])
  @@index([status])
  @@index([deletedAt])
  @@map("delivery_persons")
}

model DeliveryPersonHistory {
  id               String         @id @default(uuid())
  deliveryPersonId String         @map("delivery_person_id")
  deliveryPerson   DeliveryPerson @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)
  operacao         String
  descricao        String
  usuarioId        String?        @map("usuario_id")
  usuario          User?          @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([deliveryPersonId])
  @@index([createdAt])
  @@map("delivery_person_history")
}

model Delivery {
  id                    String          @id @default(uuid())
  orderId               String          @unique @map("order_id")
  order                 Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  deliveryPersonId      String?         @map("delivery_person_id")
  deliveryPerson        DeliveryPerson? @relation(fields: [deliveryPersonId], references: [id], onDelete: SetNull)
  status                DeliveryStatus  @default(PEDIDO_RECEBIDO)
  estimatedDeliveryTime Int?            @map("estimated_delivery_time")
  leftForDeliveryAt     DateTime?       @map("left_for_delivery_at")
  deliveredAt           DateTime?       @map("delivered_at")
  notes                 String?
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  history               DeliveryHistory[]

  @@index([status])
  @@index([deliveryPersonId])
  @@index([orderId])
  @@index([createdAt])
  @@map("deliveries")
}

model DeliveryHistory {
  id         String         @id @default(uuid())
  deliveryId String         @map("delivery_id")
  delivery   Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  status     DeliveryStatus
  usuarioId  String?        @map("usuario_id")
  usuario    User?          @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  notes      String?
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([deliveryId])
  @@index([createdAt])
  @@map("delivery_history")
}
