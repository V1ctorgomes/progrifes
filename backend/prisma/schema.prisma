generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMINISTRADOR
  GERENTE
  FUNCIONARIO
}

enum BannerType {
  HERO
  HORIZONTAL
  PROMOCIONAL
  INSTITUCIONAL
}

model User {
  id            String         @id @default(uuid())
  nome          String
  email         String         @unique
  senha         String
  cargo         UserRole       @default(FUNCIONARIO)
  ativo         Boolean        @default(true)
  ultimoLogin   DateTime?      @map("ultimo_login")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model Banner {
  id                   String     @id @default(uuid())
  nome                 String?
  titulo               String
  subtitulo            String?
  descricao            String?
  imagemDesktop        String     @map("imagem_desktop")
  imagemMobile         String?    @map("imagem_mobile")
  tipo                 BannerType
  link                 String?
  textoBotaoPrimario   String?    @map("texto_botao_primario")
  textoBotaoSecundario String?    @map("texto_botao_secundario")
  linkPrimario         String?    @map("link_primario")
  linkSecundario       String?    @map("link_secundario")
  ordem                Int        @default(0)
  ativo                Boolean    @default(true)
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  @@map("banners")
}

model Category {
  id              String     @id @default(uuid())
  nome            String
  slug            String     @unique
  descricao       String
  imagem          String
  banner          String
  categoriaPaiId  String?    @map("categoria_pai_id")
  categoriaPai    Category?  @relation("CategoryHierarchy", fields: [categoriaPaiId], references: [id], onDelete: SetNull)
  subcategorias   Category[] @relation("CategoryHierarchy")
  produtos        Product[]
  ordem           Int        @default(0)
  ativo           Boolean    @default(true)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@map("categories")
}

model Product {
  id                      String         @id @default(uuid())
  nome                    String
  slug                    String         @unique
  descricaoCurta          String         @map("descricao_curta")
  descricaoCompleta       String         @map("descricao_completa")
  categoriaId             String         @map("categoria_id")
  categoria               Category       @relation(fields: [categoriaId], references: [id])
  codigoInterno           String?        @map("codigo_interno")
  marca                   String?
  preco                   Decimal        @db.Decimal(10, 2)
  precoPromocional        Decimal?       @map("preco_promocional") @db.Decimal(10, 2)
  custo                   Decimal?       @db.Decimal(10, 2)
  mostrarPrecoPromocional Boolean        @default(false) @map("mostrar_preco_promocional")
  ativo                   Boolean        @default(true)
  destaque                Boolean        @default(false)
  novo                    Boolean        @default(false)
  ordem                   Int            @default(0)
  deletedAt               DateTime?      @map("deleted_at")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")
  imagens                 ProductImage[]
  variantes               ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id               String             @id @default(uuid())
  produtoId        String             @map("produto_id")
  produto          Product            @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  sku              String             @unique
  codigoBarras     String?            @map("codigo_barras")
  preco            Decimal?           @db.Decimal(10, 2)
  precoPromocional Decimal?           @map("preco_promocional") @db.Decimal(10, 2)
  custo            Decimal?           @db.Decimal(10, 2)
  estoque          Int                @default(0)
  estoqueMinimo    Int                @default(0) @map("estoque_minimo")
  ativo            Boolean            @default(true)
  deletedAt        DateTime?          @map("deleted_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  imagens          VariantImage[]
  atributos        VariantAttribute[]

  @@map("product_variants")
}

model VariantImage {
  id         String         @id @default(uuid())
  varianteId String         @map("variante_id")
  variante   ProductVariant @relation(fields: [varianteId], references: [id], onDelete: Cascade)
  url        String
  ordem      Int            @default(0)
  principal  Boolean        @default(false)
  createdAt  DateTime       @default(now()) @map("created_at")

  @@map("variant_images")
}

model Attribute {
  id        String           @id @default(uuid())
  nome      String           @unique
  tipo      String           @default("text")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  valores   AttributeValue[]

  @@map("attributes")
}

model AttributeValue {
  id          String             @id @default(uuid())
  attributeId String             @map("attribute_id")
  attribute   Attribute          @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  valor       String
  createdAt   DateTime           @default(now()) @map("created_at")
  variantes   VariantAttribute[]

  @@unique([attributeId, valor])
  @@map("attribute_values")
}

model VariantAttribute {
  varianteId       String         @map("variante_id")
  variante         ProductVariant @relation(fields: [varianteId], references: [id], onDelete: Cascade)
  attributeValueId String         @map("attribute_value_id")
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Restrict)

  @@id([varianteId, attributeValueId])
  @@map("variant_attributes")
}

model ProductImage {
  id        String   @id @default(uuid())
  produtoId String   @map("produto_id")
  produto   Product  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  url       String
  ordem     Int      @default(0)
  principal Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("product_images")
}
