  chartAccount       FinancialChartAccount?     @relation(fields: [chartAccountId], references: [id], onDelete: SetNull)
  costCenterId       String?                    @map("cost_center_id")
  costCenter         FinancialCostCenter?         @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  bankAccountId      String?                    @map("bank_account_id")
  bankAccount        FinancialAccount?          @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  cashboxId          String?                    @map("cashbox_id")
  cashbox            FinancialCashbox?          @relation(fields: [cashboxId], references: [id], onDelete: SetNull)
  paymentMethodId    String?                    @map("payment_method_id")
  paymentMethod      FinancialPaymentMethod?    @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
