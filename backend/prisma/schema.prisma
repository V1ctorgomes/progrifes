generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMINISTRADOR
  GERENTE
  FUNCIONARIO
}

enum BannerType {
  HERO
  HORIZONTAL
  PROMOCIONAL
  INSTITUCIONAL
}

enum OrderStatus {
  AGUARDANDO_CONFIRMACAO
  CONFIRMADO
  SEPARANDO
  PRONTO_PARA_ENTREGA
  SAIU_PARA_ENTREGA
  ENTREGUE
  CANCELADO
}

enum PaymentMethod {
  PIX
  DINHEIRO
  CARTAO_ENTREGA
}

enum PurchaseOrderStatus {
  RASCUNHO
  AGUARDANDO_APROVACAO
  APROVADA
  ENVIADA
  RECEBIMENTO_PARCIAL
  RECEBIDA
  CANCELADA
}

enum PayableStatus {
  PENDENTE
  PAGO
  PARCIALMENTE_PAGO
  VENCIDO
  CANCELADO
  ESTORNADO
}

enum PayableOriginType {
  RECEBIMENTO_MERCADORIAS
  COMPRA_MANUAL
  DESPESA_MANUAL
  FORNECEDOR
  AJUSTE_FINANCEIRO
  OUTRAS_OBRIGACOES
}

enum CashFlowType {
  ENTRADA
  SAIDA
  TRANSFERENCIA
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
}

enum CashClosingStatus {
  ABERTO
  FECHADO
}

enum ExpenseStatus {
  PENDENTE
  PAGO
  PARCIALMENTE_PAGO
  VENCIDO
  CANCELADO
  ESTORNADO
}

enum ExpenseRecurrenceFrequency {
  SEMANAL
  QUINZENAL
  MENSAL
  BIMESTRAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

enum Weekday {
  DOMINGO
  SEGUNDA_FEIRA
  TERCA_FEIRA
  QUARTA_FEIRA
  QUINTA_FEIRA
  SEXTA_FEIRA
  SABADO
}

enum DeliveryPersonStatus {
  DISPONIVEL
  EM_ENTREGA
  AUSENTE
  FOLGA
  INATIVO
}

enum DeliveryStatus {
  PEDIDO_RECEBIDO
  EM_SEPARACAO
  PRONTO_PARA_ENTREGA
  SAIU_PARA_ENTREGA
  ENTREGUE
  NAO_ENTREGUE
  CANCELADO
}

enum PayableGenerationMode {
  PER_RECEIPT
  AT_COMPLETION
}

enum FinancialAccountType {
  CONTA_CORRENTE
  CONTA_POUPANCA
  CONTA_DIGITAL
}

enum FinancialTransactionType {
  RECEITA
  DESPESA
  TRANSFERENCIA
  AJUSTE
}

enum FinancialTransactionStatus {
  PENDENTE
  RECEBIDO
  PAGO
  CANCELADO
  VENCIDO
  PARCIALMENTE_PAGO
}

enum FinancialOriginType {
  PEDIDO
  COMPRA
  RECEBIMENTO
  CLIENTE
  FORNECEDOR
  DESPESA
  TRANSFERENCIA
  AJUSTE
  LANCAMENTO_MANUAL
}

enum ChartAccountType {
  RECEITA
  DESPESA
}

enum ReceivableOriginType {
  PEDIDO
  VENDA_MANUAL
  LANCAMENTO_MANUAL
  AJUSTE_FINANCEIRO
  OUTRAS_RECEITAS
}

enum ReceivableStatus {
  PENDENTE
  RECEBIDO
  PARCIALMENTE_RECEBIDO
  VENCIDO
  CANCELADO
  ESTORNADO
}

model User {
  id            String         @id @default(uuid())
  nome          String
  email         String         @unique
  senha         String
  cargo         UserRole       @default(FUNCIONARIO)
  ativo         Boolean        @default(true)
  ultimoLogin   DateTime?      @map("ultimo_login")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  orderHistory  OrderHistory[]
  customerNotes CustomerNote[]
  clientesResponsavel Customer[] @relation("CustomerResponsavel")
  entradasEstoque InventoryEntry[]
  movimentosEstoque InventoryMovement[]
  inventariosEstoque InventoryAudit[]
  ordensCompra PurchaseOrder[]
  historicoOrdensCompra PurchaseOrderHistory[]
  recebimentos GoodsReceipt[]
  contasPagar AccountPayable[]
  lancamentosFinanceiros FinancialTransaction[]
  historicoFinanceiro FinancialTransactionHistory[]
  contasReceber AccountReceivable[]
  recebimentosContasReceber AccountReceivableReceipt[]
  historicoContasReceber AccountReceivableHistory[]
  pagamentosContasPagar AccountPayablePayment[]
  historicoContasPagar AccountPayableHistory[]
  transferenciasCashFlow CashTransfer[]
  fechamentosCaixa CashClosing[]
  movimentosFluxoCaixa CashFlowEntry[]
  despesas Expense[]
  anexosDespesas ExpenseAttachment[]
  historicoDespesas ExpenseHistory[]
  historicoEntrega DeliverySettingsHistory[]
  historicoBairrosEntrega DeliveryNeighborhoodHistory[]
  historicoEntregadores DeliveryPersonHistory[]
  historicoAcompanhamentoEntregas DeliveryHistory[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model Banner {
  id                   String     @id @default(uuid())
  nome                 String?
  titulo               String
  subtitulo            String?
  descricao            String?
  imagemDesktop        String     @map("imagem_desktop")
  imagemMobile         String?    @map("imagem_mobile")
  tipo                 BannerType
  link                 String?
  textoBotaoPrimario   String?    @map("texto_botao_primario")
  textoBotaoSecundario String?    @map("texto_botao_secundario")
  linkPrimario         String?    @map("link_primario")
  linkSecundario       String?    @map("link_secundario")
  ordem                Int        @default(0)
  ativo                Boolean    @default(true)
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  @@map("banners")
}

model Category {
  id              String     @id @default(uuid())
  nome            String
  slug            String     @unique
  descricao       String
  imagem          String
  banner          String
  categoriaPaiId  String?    @map("categoria_pai_id")
  categoriaPai    Category?  @relation("CategoryHierarchy", fields: [categoriaPaiId], references: [id], onDelete: SetNull)
  subcategorias   Category[] @relation("CategoryHierarchy")
  produtos        Product[]
  inventariosEstoque InventoryAudit[]
  ordem           Int        @default(0)
  ativo           Boolean    @default(true)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@map("categories")
}

model Product {
  id                      String         @id @default(uuid())
  nome                    String
  slug                    String         @unique
  descricaoCurta          String         @map("descricao_curta")
  descricaoCompleta       String         @map("descricao_completa")
  categoriaId             String         @map("categoria_id")
  categoria               Category       @relation(fields: [categoriaId], references: [id])
  codigoInterno           String?        @map("codigo_interno")
  marca                   String?
  preco                   Decimal        @db.Decimal(10, 2)
  precoPromocional        Decimal?       @map("preco_promocional") @db.Decimal(10, 2)
  custo                   Decimal?       @db.Decimal(10, 2)
  mostrarPrecoPromocional Boolean        @default(false) @map("mostrar_preco_promocional")
  ativo                   Boolean        @default(true)
  destaque                Boolean        @default(false)
  novo                    Boolean        @default(false)
  ordem                   Int            @default(0)
  deletedAt               DateTime?      @map("deleted_at")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")
  imagens                 ProductImage[]
  variantes               ProductVariant[]
  inventariosEstoque      InventoryAudit[]
  orderItems              OrderItem[]
  itensOrdemCompra        PurchaseOrderItem[]

  @@map("products")
}

enum InventoryEntryType {
  COMPRA
  REPOSICAO
  DEVOLUCAO_CLIENTE
  AJUSTE_POSITIVO
  PRODUCAO
  OUTROS
}

enum InventoryMovementType {
  ENTRADA
  SAIDA
  RESERVA
  LIBERACAO
  BAIXA
}

enum InventoryStatus {
  EM_ESTOQUE
  ESTOQUE_BAIXO
  SEM_ESTOQUE
}

enum InventoryAuditType {
  GERAL
  PARCIAL
  CATEGORIA
  PRODUTO
  VARIANTE
}

enum InventoryAuditStatus {
  RASCUNHO
  EM_ANDAMENTO
  PAUSADO
  FINALIZADO
  CANCELADO
}

enum InventoryAdjustmentType {
  ENTRADA
  SAIDA
  NENHUM
}

model Inventory {
  id                  String              @id @default(uuid())
  variantId           String              @unique @map("variant_id")
  variant             ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantidadeTotal     Int                 @default(0) @map("quantidade_total")
  quantidadeReservada Int                 @default(0) @map("quantidade_reservada")
  quantidadeDisponivel Int                @default(0) @map("quantidade_disponivel")
  estoqueMinimo       Int                 @default(0) @map("estoque_minimo")
  status              InventoryStatus     @default(SEM_ESTOQUE)
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([status])
  @@map("inventory")
}

model InventoryEntry {
  id            String             @id @default(uuid())
  numero        Int                @unique
  variantId     String             @map("variant_id")
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Restrict)
  tipo          InventoryEntryType
  quantidade    Int
  valorUnitario Decimal?           @map("valor_unitario") @db.Decimal(10, 2)
  documento     String?
  notaFiscal    String?            @map("nota_fiscal")
  fornecedor    String?
  observacoes   String?
  usuarioId     String?            @map("usuario_id")
  usuario       User?              @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  dataEntrada   DateTime           @default(now()) @map("data_entrada")
  goodsReceiptId String?           @map("goods_receipt_id")
  goodsReceipt   GoodsReceipt?      @relation(fields: [goodsReceiptId], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now()) @map("created_at")
  movimento     InventoryMovement?

  @@index([variantId])
  @@index([tipo])
  @@index([dataEntrada])
  @@map("inventory_entries")
}

model InventoryMovement {
  id            String                 @id @default(uuid())
  numero        Int?                   @unique
  variantId     String                 @map("variant_id")
  variant       ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Cascade)
  orderId       String?                @map("order_id")
  order         Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  entryId       String?                @unique @map("entry_id")
  entry         InventoryEntry?        @relation(fields: [entryId], references: [id], onDelete: SetNull)
  auditId       String?                @map("audit_id")
  audit         InventoryAudit?        @relation(fields: [auditId], references: [id], onDelete: SetNull)
  usuarioId     String?                @map("usuario_id")
  usuario       User?                  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  tipo          InventoryMovementType
  origem        String?
  quantidade    Int
  saldoAnterior Int?                   @map("saldo_anterior")
  saldoAtual    Int?                   @map("saldo_atual")
  referenciaId  String?                @map("referencia_id")
  motivo        String?
  documento     String?
  descricao     String
  createdAt     DateTime               @default(now()) @map("created_at")

  @@index([variantId])
  @@index([orderId])
  @@index([tipo])
  @@index([origem])
  @@index([createdAt])
  @@index([auditId])
  @@map("inventory_movements")
}

model InventoryAudit {
  id              String               @id @default(uuid())
  numero          Int                  @unique
  nome            String
  tipo            InventoryAuditType
  status          InventoryAuditStatus @default(RASCUNHO)
  categoriaId     String?              @map("categoria_id")
  categoria       Category?            @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  produtoId       String?              @map("produto_id")
  produto         Product?             @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  variantId       String?              @map("variant_id")
  variant         ProductVariant?      @relation("InventoryAuditVariant", fields: [variantId], references: [id], onDelete: SetNull)
  usuarioId       String               @map("usuario_id")
  usuario         User                 @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  observacoes     String?
  dataInventario  DateTime             @default(now()) @map("data_inventario")
  createdAt       DateTime             @default(now()) @map("created_at")
  finishedAt      DateTime?            @map("finished_at")
  itens           InventoryAuditItem[]
  movimentos      InventoryMovement[]

  @@index([status])
  @@index([tipo])
  @@index([dataInventario])
  @@index([usuarioId])
  @@map("inventory_audits")
}

model InventoryAuditItem {
  id                 String                  @id @default(uuid())
  auditId            String                  @map("audit_id")
  audit              InventoryAudit          @relation(fields: [auditId], references: [id], onDelete: Cascade)
  variantId          String                  @map("variant_id")
  variant            ProductVariant          @relation(fields: [variantId], references: [id], onDelete: Restrict)
  quantidadeSistema  Int                     @map("quantidade_sistema")
  quantidadeFisica   Int?                    @map("quantidade_fisica")
  diferenca          Int?
  tipoAjuste         InventoryAdjustmentType? @map("tipo_ajuste")
  contado            Boolean                 @default(false)
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  @@unique([auditId, variantId])
  @@index([variantId])
  @@map("inventory_audit_items")
}

model ProductVariant {
  id               String             @id @default(uuid())
  produtoId        String             @map("produto_id")
  produto          Product            @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  sku              String             @unique
  codigoBarras     String?            @map("codigo_barras")
  preco            Decimal?           @db.Decimal(10, 2)
  precoPromocional Decimal?           @map("preco_promocional") @db.Decimal(10, 2)
  custo            Decimal?           @db.Decimal(10, 2)
  estoque          Int                @default(0)
  estoqueMinimo    Int                @default(0) @map("estoque_minimo")
  ativo            Boolean            @default(true)
  deletedAt        DateTime?          @map("deleted_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  imagens          VariantImage[]
  atributos        VariantAttribute[]
  orderItems       OrderItem[]
  inventory        Inventory?
  entradasEstoque  InventoryEntry[]
  movimentosEstoque InventoryMovement[]
  itensInventario  InventoryAuditItem[]
  inventariosAlvo  InventoryAudit[] @relation("InventoryAuditVariant")
  itensOrdemCompra PurchaseOrderItem[]
  itensRecebimento GoodsReceiptItem[]

  @@map("product_variants")
}

model VariantImage {
  id         String         @id @default(uuid())
  varianteId String         @map("variante_id")
  variante   ProductVariant @relation(fields: [varianteId], references: [id], onDelete: Cascade)
  url        String
  ordem      Int            @default(0)
  principal  Boolean        @default(false)
  createdAt  DateTime       @default(now()) @map("created_at")

  @@map("variant_images")
}

model Attribute {
  id        String           @id @default(uuid())
  nome      String           @unique
  tipo      String           @default("text")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  valores   AttributeValue[]

  @@map("attributes")
}

model AttributeValue {
  id          String             @id @default(uuid())
  attributeId String             @map("attribute_id")
  attribute   Attribute          @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  valor       String
  createdAt   DateTime           @default(now()) @map("created_at")
  variantes   VariantAttribute[]

  @@unique([attributeId, valor])
  @@map("attribute_values")
}

model VariantAttribute {
  varianteId       String         @map("variante_id")
  variante         ProductVariant @relation(fields: [varianteId], references: [id], onDelete: Cascade)
  attributeValueId String         @map("attribute_value_id")
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Restrict)

  @@id([varianteId, attributeValueId])
  @@map("variant_attributes")
}

model ProductImage {
  id        String   @id @default(uuid())
  produtoId String   @map("produto_id")
  produto   Product  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  url       String
  ordem     Int      @default(0)
  principal Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("product_images")
}

model Customer {
  id                    String                 @id @default(uuid())
  nome                  String
  telefone              String                 @unique
  email                 String?
  cpf                   String?
  dataNascimento        DateTime?              @map("data_nascimento")
  observacoes           String?
  origem                String?
  canalAtendimento      String?                @map("canal_atendimento")
  responsavelId         String?                @map("responsavel_id")
  responsavel           User?                  @relation("CustomerResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  observacoesComerciais String?                @map("observacoes_comerciais")
  ativo                 Boolean                @default(true)
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  enderecos             CustomerAddress[]
  pedidos               Order[]
  notas                 CustomerNote[]
  tags                  CustomerTagRelation[]
  contasReceber         AccountReceivable[]

  @@index([nome])
  @@index([email])
  @@index([cpf])
  @@map("customers")
}

model CustomerNote {
  id         String    @id @default(uuid())
  customerId String    @map("customer_id")
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  usuarioId  String?   @map("usuario_id")
  usuario    User?     @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  descricao  String
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([customerId])
  @@map("customer_notes")
}

model CustomerTag {
  id        String                @id @default(uuid())
  nome      String                @unique
  cor       String                @default("#111111")
  createdAt DateTime              @default(now()) @map("created_at")
  clientes  CustomerTagRelation[]

  @@map("customer_tags")
}

model CustomerTagRelation {
  customerId String      @map("customer_id")
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tagId      String      @map("tag_id")
  tag        CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now()) @map("created_at")

  @@id([customerId, tagId])
  @@map("customer_tag_relations")
}

model CustomerAddress {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  cep         String
  rua         String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String
  referencia  String?
  principal   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([cidade])
  @@index([bairro])
  @@map("customer_addresses")
}

model Supplier {
  id                String            @id @default(uuid())
  razaoSocial       String            @map("razao_social")
  nomeFantasia      String            @map("nome_fantasia")
  cnpj              String            @unique
  inscricaoEstadual String?           @map("inscricao_estadual")
  telefone          String
  email             String?
  website           String?
  contatoPrincipal  String?           @map("contato_principal")
  observacoes       String?
  ativo             Boolean           @default(true)
  deletedAt         DateTime?         @map("deleted_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  endereco          SupplierAddress?
  contatos          SupplierContact[]
  ordensCompra      PurchaseOrder[]
  contasPagar       AccountPayable[]
  despesas          Expense[]

  @@index([nomeFantasia])
  @@index([razaoSocial])
  @@map("suppliers")
}

model SupplierAddress {
  id          String   @id @default(uuid())
  supplierId  String   @unique @map("supplier_id")
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  cep         String
  rua         String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([cidade])
  @@index([estado])
  @@map("supplier_addresses")
}

model SupplierContact {
  id         String   @id @default(uuid())
  supplierId String   @map("supplier_id")
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  nome       String
  cargo      String?
  telefone   String?
  whatsapp   String?
  email      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([supplierId])
  @@map("supplier_contacts")
}

model PurchaseOrder {
  id                 String              @id @default(uuid())
  numero             Int                 @unique
  supplierId         String              @map("supplier_id")
  supplier           Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  status             PurchaseOrderStatus @default(RASCUNHO)
  data               DateTime            @default(now())
  previsaoEntrega    DateTime            @map("previsao_entrega")
  frete              Decimal             @default(0) @db.Decimal(10, 2)
  desconto           Decimal             @default(0) @db.Decimal(10, 2)
  subtotal           Decimal             @db.Decimal(10, 2)
  total              Decimal             @db.Decimal(10, 2)
  pedidoFornecedor   String?             @map("pedido_fornecedor")
  observacoes        String?
  motivoCancelamento String?             @map("motivo_cancelamento")
  usuarioId          String?             @map("usuario_id")
  usuario            User?               @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  aprovadaEm         DateTime?           @map("aprovada_em")
  enviadaEm          DateTime?           @map("enviada_em")
  recebidaEm         DateTime?           @map("recebida_em")
  canceladaEm        DateTime?           @map("cancelada_em")
  deletedAt          DateTime?           @map("deleted_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  itens              PurchaseOrderItem[]
  historico          PurchaseOrderHistory[]
  recebimentos       GoodsReceipt[]
  contasPagar        AccountPayable[]

  @@index([supplierId])
  @@index([numero])
  @@index([status])
  @@index([usuarioId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String         @id @default(uuid())
  purchaseOrderId String         @map("purchase_order_id")
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String         @map("product_id")
  product         Product        @relation(fields: [productId], references: [id])
  variantId       String         @map("variant_id")
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  produtoNome     String         @map("produto_nome")
  sku             String
  quantidade      Int
  valorUnitario   Decimal        @map("valor_unitario") @db.Decimal(10, 2)
  desconto        Decimal        @default(0) @db.Decimal(10, 2)
  subtotal        Decimal        @db.Decimal(10, 2)
  itensRecebimento GoodsReceiptItem[]

