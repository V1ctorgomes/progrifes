# Desenvolvimento local
BACKEND_URL=http://localhost:3001

# EasyPanel (produção) — obrigatório no serviço frontend:
# BACKEND_URL=https://progrifes-backend.pknzmz.easypanel.host

# No backend (CORS), configure também a origem do frontend:
# CORS_ORIGIN=https://progrifes-frontend.pknzmz.easypanel.host

# No backend (cookies HTTPS), em produção:
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=lax
